# SQLite (local dev). Use PostgreSQL in production.
DATABASE_URL="file:./prisma/dev.db"

# API
PORT=3000

# JWT for password login (use a long random string in production)
JWT_SECRET="change-me-in-production-use-openssl-rand-hex-32"

# Later: OAuth (e.g. Google), cookie session
# SESSION_SECRET=
# GOOGLE_CLIENT_ID=

# Later: IPFS / Arweave
# IPFS_JWT=
# IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# Later: chain RPC (only for tips / ownership features)
# RPC_URL=
