# SQLite (local dev). Use PostgreSQL in production.
DATABASE_URL="file:./prisma/dev.db"

# API
PORT=3000

# JWT for password login — set only in local `.env` (gitignored). Never commit real values.
# Generate: `openssl rand -hex 32` (must be at least 16 characters for the server to start).
JWT_SECRET=

# Later: OAuth (e.g. Google), cookie session
# SESSION_SECRET=
# GOOGLE_CLIENT_ID=

# Later: IPFS / Arweave
# IPFS_JWT=
# IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# Later: chain RPC (only for tips / ownership features)
# RPC_URL=
